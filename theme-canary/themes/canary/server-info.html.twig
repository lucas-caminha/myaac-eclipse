<script>
  var serverSaveTime = new Date({{ serverSaveTime }});
  var x = setInterval(function() {
    var now = new Date().getTime();
    var distance = serverSaveTime - now;
    var hours = Math.floor(distance / (1000 * 60 * 60));
    var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
    var seconds = Math.floor((distance % (1000 * 60)) / 1000);
    hours = hours < 10 ? "0" + hours : hours;
    minutes = minutes < 10 ? "0" + minutes : minutes;
    seconds = seconds < 10 ? "0" + seconds : seconds;

    document.getElementById("timerServerSave_hour").innerHTML = hours + "h";
    document.getElementById("timerServerSave_minute").innerHTML = minutes + "m";
    document.getElementById("timerServerSave_second").innerHTML = seconds + "s";

    if (distance < 0) {
      clearInterval(x);
      document.getElementById("timerServerSave_hour").innerHTML = "Agora";
      document.getElementById("timerServerSave_minute").innerHTML = "";
      document.getElementById("timerServerSave_second").innerHTML = "";
    }
  }, 1000);
</script>

<div class="eclipse-server-info">
  <section class="serverinfo-hero">
    <h1>{{ config.lua.serverName }}</h1>
    <nav class="serverinfo-nav">
      <a href="#server-commands">Comandos</a>
      <a href="#server-details">Informações</a>
      <a href="#server-rates">Rates</a>
      <a href="#server-pvp">PvP</a>
    </nav>
  </section>

  <section id="server-commands" class="serverinfo-card serverinfo-commands-card">
    <div class="serverinfo-card-title">Comandos</div>
    <div class="serverinfo-commands-body">
      {% if commandsPage %}
        {{ commandsPage.body|raw }}
      {% else %}
        <p>Os comandos do servidor serão exibidos aqui quando estiverem cadastrados no painel.</p>
      {% endif %}
    </div>
  </section>

  <div class="serverinfo-grid serverinfo-grid-top">
    <section class="serverinfo-card serverinfo-save-card">
      <div class="serverinfo-card-title">Server Save</div>
      <p class="serverinfo-muted">Todos os dias às {{ serverSave.0 }}:{{ serverSave.1 }}</p>
      <div class="serverinfo-countdown">
        <div>
          <span id="timerServerSave_hour"></span>
          <small>horas</small>
        </div>
        <div>
          <span id="timerServerSave_minute"></span>
          <small>minutos</small>
        </div>
        <div>
          <span id="timerServerSave_second"></span>
          <small>segundos</small>
        </div>
      </div>
    </section>

    <section id="server-details" class="serverinfo-card">
      <div class="serverinfo-card-title">Informações do Servidor</div>
      <dl class="serverinfo-list">
        <div><dt>IP</dt><dd>{{ serverIp }} (porta {{ config.lua.loginPort ?? config.lua.loginProtocolPort }})</dd></div>
        <div><dt>Cliente</dt><dd>{{ clientVersion }}</dd></div>
        <div><dt>Uptime</dt><dd>{{ status.uptimeReadable }}</dd></div>
        <div><dt>Global Save</dt><dd>{{ serverSave.0 }}:{{ serverSave.1 }}</dd></div>
        <div><dt>Tipo de Mundo</dt><dd>{{ config.lua.worldType|upper }}</dd></div>
        <div><dt>Protection Level</dt><dd>{{ protectionLevel }}</dd></div>
        <div><dt>Loot</dt><dd>x{{ rateLoot }}</dd></div>
        <div><dt>Spawn</dt><dd>x{{ rateSpawn }}</dd></div>
        <div><dt>Aluguel de casas</dt><dd>{{ houseRent }}</dd></div>
        <div><dt>Nível para guild</dt><dd>{% if config.guild_need_level > 0 %}{{ config.guild_need_level }}{% else %}sem requisito{% endif %}</dd></div>
        {% if houseLevel %}
          <div><dt>Nível para comprar casa</dt><dd>{{ houseLevel }}</dd></div>
        {% endif %}
      </dl>
      {% if houseOld %}
        <p class="serverinfo-muted">Casas com donos inativos são limpas após 30 dias.</p>
      {% endif %}
    </section>
  </div>

  <div id="server-rates" class="serverinfo-grid">
    <section class="serverinfo-card">
      <div class="serverinfo-card-title">Rates</div>
      {% if not rateUseStages %}
        <div class="serverinfo-rate-tiles">
          <div><span>x{{ rateExp }}</span><small>Experiência</small></div>
          <div><span>x{{ rateMagic }}</span><small>Magic Level</small></div>
          <div><span>x{{ rateSkill }}</span><small>Skills</small></div>
        </div>
      {% else %}
        <div class="serverinfo-stage-table-wrap">
          <h3>Experiência</h3>
          <table class="serverinfo-table">
            <thead>
            <tr><th>De</th><th>Até</th><th>Rate</th></tr>
            </thead>
            <tbody>
            {% for result in rateStages.experienceStages %}
              <tr>
                <td>{{ result.minlevel }}</td>
                <td>{% if result.maxlevel is not empty %}{{ result.maxlevel }}{% else %}-{% endif %}</td>
                <td>{{ result.multiplier }}x</td>
              </tr>
            {% endfor %}
            </tbody>
          </table>

          <h3>Skills</h3>
          <table class="serverinfo-table">
            <thead>
            <tr><th>De</th><th>Até</th><th>Rate</th></tr>
            </thead>
            <tbody>
            {% for result in rateStages.skillsStages %}
              <tr>
                <td>{{ result.minlevel }}</td>
                <td>{% if result.maxlevel is not empty %}{{ result.maxlevel }}{% else %}-{% endif %}</td>
                <td>{{ result.multiplier }}x</td>
              </tr>
            {% endfor %}
            </tbody>
          </table>

          <h3>Magic Level</h3>
          <table class="serverinfo-table">
            <thead>
            <tr><th>De</th><th>Até</th><th>Rate</th></tr>
            </thead>
            <tbody>
            {% for result in rateStages.magicLevelStages %}
              <tr>
                <td>{{ result.minlevel }}</td>
                <td>{% if result.maxlevel is not empty %}{{ result.maxlevel }}{% else %}-{% endif %}</td>
                <td>{{ result.multiplier }}x</td>
              </tr>
            {% endfor %}
            </tbody>
          </table>
        </div>
      {% endif %}
    </section>

    <section id="server-pvp" class="serverinfo-card">
      <div class="serverinfo-card-title">Sistema PvP</div>
      <dl class="serverinfo-list">
        <div><dt>PZ Lock</dt><dd>{{ pzLocked / (60 * 1000) }} min</dd></div>
        <div><dt>Duração do frag</dt><dd>7 horas</dd></div>
        <div><dt>Red Skull</dt><dd>{{ redSkullDuration }} dias</dd></div>
        {% if blackSkullDuration %}
          <div><dt>Black Skull</dt><dd>{{ blackSkullDuration }} dias</dd></div>
        {% endif %}
        {% if dailyFragsToRedSkull is defined %}
          <div><dt>Red Skull</dt><dd>{{ dailyFragsToRedSkull }} diário / {{ weeklyFragsToRedSkull }} semanal / {{ monthlyFragsToRedSkull }} mensal</dd></div>
          <div><dt>Black Skull</dt><dd>{{ dailyFragsToRedSkull * 2 }} diário / {{ weeklyFragsToRedSkull * 2 }} semanal / {{ monthlyFragsToRedSkull * 2 }} mensal</dd></div>
        {% endif %}
      </dl>
    </section>
  </div>

  <p class="serverinfo-footer-note">Denuncie violações de regras dentro do jogo usando CTRL + R.</p>
</div>
