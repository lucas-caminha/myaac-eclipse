{% set title = 'Equipe do Servidor' %}
{% set content %}
{% set i = 0 %}

<div class="eclipse-directory-page eclipse-team-page">
	<div class="directory-note">
		<strong>Equipe do Servidor</strong>
		<span>Jogadores responsaveis pelo suporte e administracao do Eclipse OT.</span>
	</div>

	{% for group in groupmember|reverse %}
		{% if group.members is not empty %}
			<div class="directory-card team-group-card">
				<div class="directory-card-title">{{ group.group_name|capitalize }}</div>
				<table class="directory-table team-table">
					<tbody>
					<tr class="LabelH">
						{% if setting('core.team_outfit') %}
							<td class="team-outfit-cell">Outfit</td>
						{% endif %}
						<td>Nome</td>
						{% if setting('core.team_status') %}
							<td>Status</td>
						{% endif %}
						{% if (setting('core.multiworld') or setting('core.team_world')) %}
							<td>Mundo</td>
						{% endif %}
						{% if setting('core.team_lastlogin') %}
							<td>Ultimo login</td>
						{% endif %}
					</tr>

					{% for member in group.members|reverse %}
						{% set i = i + 1 %}
						<tr>
							{% if setting('core.team_outfit') %}
								<td class="team-outfit-cell">
									<img src="{{ member.outfit }}" alt="outfit">
								</td>
							{% endif %}
							<td>
								{% if setting('core.account_country') %}
									{{ member.flag_image|raw }}
								{% endif %}
								{{ member.link|raw }}
							</td>
							{% if setting('core.team_status') %}
								<td>
									{% if member.status %}
										<span class="status-online">Online</span>
									{% else %}
										<span class="status-offline">Offline</span>
									{% endif %}
								</td>
							{% endif %}
							{% if (setting('core.multiworld') or setting('core.team_world')) %}
								<td><strong>{{ member.world_name }}</strong></td>
							{% endif %}
							{% if setting('core.team_lastlogin') %}
								<td>{{ member.last_login }}</td>
							{% endif %}
						</tr>
					{% endfor %}
					</tbody>
				</table>
			</div>
		{% endif %}
	{% else %}
		<div class="directory-card">
			<div class="directory-empty">Nenhum membro da equipe foi encontrado.</div>
		</div>
	{% endfor %}
</div>

{% endset %}
{% include 'tables.headline.html.twig' %}
