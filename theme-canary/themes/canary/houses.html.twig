{% set title = 'Casas' %}
{% set content %}

<div class="eclipse-directory-page eclipse-houses-page">
	{% if errors is not empty %}
		<div class="directory-note directory-error">
			{% for error in errors %}
				<p>{{ error }}</p>
			{% endfor %}
		</div>
	{% else %}
		<div class="directory-note">
			<strong>Casas e Guildhalls</strong>
			<span>Consulte casas disponiveis, alugadas e guildhalls do Eclipse OT.</span>
		</div>

		{% if cleanOldHouse is not empty or rentType != 'never' %}
			<div class="directory-hint">
				A limpeza automatica acontece durante o server save. Casas de donos inativos por {{ cleanOldHouse }} dias{% if rentType != 'never' %} ou com aluguel {{ rentType }} em atraso{% endif %} podem ser liberadas.
			</div>
		{% endif %}

		{% if houses is not empty or housesSearch %}
			<div class="directory-card">
				<div class="directory-card-title">Disponibilidade{% if townName is not empty %} em {{ townName }}{% endif %}</div>
				<table class="directory-table">
					<tbody>
					{% if houses is not empty %}
						<tr class="LabelH">
							<td>Nome</td>
							<td>Tamanho</td>
							<td>Aluguel</td>
							<td>Status</td>
							<td></td>
						</tr>

						{% for house in houses %}
							<tr>
								<td><strong>{{ house.name }}</strong></td>
								<td>{{ house.size }} sqm</td>
								<td>{{ house.rent }} gold</td>
								<td>{{ house.rentedBy|raw }}</td>
								<td class="directory-action">
									<a href="{{ house.link }}">{{ include('buttons.view.html.twig') }}</a>
								</td>
							</tr>
						{% endfor %}
					{% else %}
						<tr>
							<td class="directory-empty">Nenhuma casa encontrada com esses filtros.</td>
						</tr>
					{% endif %}
					</tbody>
				</table>
			</div>
		{% endif %}

		<form action="{{ getLink('houses') }}" method="post" class="directory-card directory-form">
			<div class="directory-card-title">Buscar Casas</div>
			<div class="houses-filter-grid">
				<div>
					<strong>Cidade</strong>
					{% set checked = false %}
					{% for id, name in config.towns %}
						{% if id > 0 %}
							{% if ((townId is empty and name is not empty) or id == townId) and not checked %}
								{% set variable = "checked" %}
								{% set checked = true %}
							{% else %}
								{% set variable = "" %}
							{% endif %}
							<label><input type="radio" name="town" value="{{ id }}"{% if variable is defined %} {{ variable }}{% endif %}> {{ name }}</label>
						{% endif %}
					{% endfor %}
				</div>

				<div>
					<strong>Status</strong>
					<label><input type="radio" name="state" value=""{% if state is empty %} checked{% endif %}> todos</label>
					<label><input type="radio" name="state" value="free"{% if state == 'free' %} checked{% endif %}> livres</label>
					<label><input type="radio" name="state" value="rented"{% if state == 'rented' %} checked{% endif %}> alugadas</label>
				</div>

				<div>
					<strong>Ordenar por</strong>
					<label><input type="radio" name="order" value=""{% if order is empty %} checked{% endif %}> nome</label>
					<label><input type="radio" name="order" value="size"{% if order == 'size' %} checked{% endif %}> tamanho</label>
					<label><input type="radio" name="order" value="rent"{% if order == 'rent' %} checked{% endif %}> aluguel</label>
				</div>

				<div>
					<strong>Tipo</strong>
					<label><input type="radio" name="type" value=""{% if type is empty %} checked{% endif %}> todos</label>
					<label><input type="radio" name="type" value="houses"{% if type == 'houses' %} checked{% endif %}> casas e flats</label>
					<label><input type="radio" name="type" value="guildhalls"{% if type == 'guildhalls' %} checked{% endif %}> guildhalls</label>
				</div>
			</div>

			<div class="directory-submit">
				{{ include('buttons.submit.html.twig') }}
			</div>
		</form>
	{% endif %}
</div>

{% endset %}
{% include 'tables.headline.html.twig' %}
