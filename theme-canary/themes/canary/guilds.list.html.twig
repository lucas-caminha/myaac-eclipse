{% set title = 'Guildas Ativas - ' ~ config.lua.serverName %}
{% set content %}

<div class="eclipse-directory-page eclipse-guilds-page">
	<div class="directory-note">
		<strong>Guildas Ativas</strong>
		<span>Veja as comunidades organizadas no Eclipse OT.</span>
	</div>

	<div class="directory-card">
		<div class="directory-card-title">Lista de Guildas</div>
		<table class="directory-table guilds-table">
			<tbody>
			{% if guilds|length > 0 %}
				<tr class="LabelH">
					<td class="guild-logo-cell">Logo</td>
					<td>Descricao</td>
					<td></td>
				</tr>

				{% for guild in guilds %}
					<tr>
						<td class="guild-logo-cell">
							<img src="{{ constant('GUILD_IMAGES_DIR') }}{{ guild.logo }}" width="64" height="64" alt="{{ guild.name }}">
						</td>
						<td class="guild-description-cell">
							<strong>{{ guild.name }}</strong>
							{% if isAdmin %}
								<a href="{{ getLink('guilds') }}?action=delete_by_admin&guild={{ guild.name }}"> - deletar</a>
							{% endif %}
							{% if guild.description is not empty %}
								<p>{{ guild.description }}</p>
							{% else %}
								<p>Esta guilda ainda nao possui descricao publica.</p>
							{% endif %}
						</td>
						<td class="directory-action">
							<form action="{{ guild.link }}" method="post">
								{{ csrf() }}
								{{ include('buttons.view.html.twig') }}
							</form>
						</td>
					</tr>
				{% endfor %}
			{% else %}
				<tr>
					<td class="directory-empty">
						Nenhuma guilda ativa encontrada.
						{% if logged %}Voce pode criar a primeira guilda do servidor.{% endif %}
					</td>
				</tr>
			{% endif %}
			</tbody>
		</table>
	</div>

	<div class="directory-note guilds-action-note">
		{% if logged %}
			<span>Nao encontrou uma guilda para chamar de sua?</span>
			<form action="{{ getLink('guilds') }}?action=create" method="post">
				{{ csrf() }}
				{% set button_name = 'Found Guild' %}
				{% set button_image = '_sbutton_foundguild' %}
				{% include('buttons.base.html.twig') %}
			</form>
		{% else %}
			<span>Entre na sua conta para criar uma guilda.</span>
			<form action="{{ getLink('account/manage') }}?redirect={{ getLink('guilds') }}" method="post">
				{{ csrf() }}
				{% include('buttons.login.html.twig') %}
			</form>
		{% endif %}
	</div>
</div>

{% endset %}
{% include 'tables.headline.html.twig' %}
