											</tr>
											</tbody>
										</table>
									</td>
								</tr>
								{% endif %}

								{{ hook('HOOK_ACCOUNT_CREATE_AFTER_TOWNS') }}

								</tbody>
							</table>
						</div>
					</div>
					<div class="TableShadowContainer">
						<div class="TableBottomShadow" style="background-image:url({{ template_path }}/images/global/content/table-shadow-bm.gif);">
							<div class="TableBottomLeftShadow" style="background-image:url({{ template_path }}/images/global/content/table-shadow-bl.gif);"></div>
							<div class="TableBottomRightShadow" style="background-image:url({{ template_path }}/images/global/content/table-shadow-br.gif);"></div>
						</div>
					</div>
				</td>
			</tr>
			{% endif %}

			{{ hook('HOOK_ACCOUNT_CREATE_BETWEEN_BOXES_2') }}

			<tr>
				<td>
					<div class="TableShadowContainerRightTop">
						<div class="TableShadowRightTop" style="background-image:url({{ template_path }}/images/global/content/table-shadow-rt.gif);"></div>
					</div>
					<div class="TableContentAndRightShadow" style="background-image:url({{ template_path }}/images/global/content/table-shadow-rm.gif);">
						<div class="TableContentContainer">
							<table class="TableContent eclipse-registration-panel is-locked" data-registration-panel="rules" width="100%" style="border:1px solid #faf0d7;">
								<tbody>
								<tr class="eclipse-registration-panel-intro">
									<td colspan="2">
										<strong>Finalize com as regras do servidor</strong>
										<span>Essa etapa libera quando as informacoes anteriores estiverem preenchidas.</span>
									</td>
								</tr>
								<tr>
									<td colspan="2" ><b>Confirme a leitura das regras:</b></td>
								</tr>
								<tr>
									<td colspan="2" >
										<span><input type="checkbox" id="accept_rules" name="accept_rules" value="true"{% if accept_rules %}checked{% endif %}/> <label for="accept_rules">Eu li e aceito as <a href="?subtopic=rules" target="_blank">regras do {{ config.lua.serverName }}</a>.</label></span>
									</td>
								</tr>
