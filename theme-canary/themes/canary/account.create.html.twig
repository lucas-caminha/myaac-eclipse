	{% endset %}
	{% include 'tables.headline.html.twig' %}

	<br/>
	{{ hook('HOOK_ACCOUNT_CREATE_BEFORE_SUBMIT_BUTTON') }}
	<table width="100%">
		<tr align="center">
			<td>
				<table border="0" cellspacing="0" cellpadding="0" >
					<tr>
						<td style="border:0px;" >
							<input type="hidden" name="save" value="1" >
							{% set button_name = 'Criar conta' %}
							{{ include('buttons.submit.html.twig') }}
						</td>
					</tr>
				</table>
			</td>
		</tr>
	</table>
</form>
</div>
{{ hook('HOOK_ACCOUNT_CREATE_AFTER_FORM') }}
<script type="text/javascript" src="{{ constant('BASE_URL') }}tools/check_name.js"></script>
<script>
	(function () {
		var form = document.getElementById('createaccount');
		if (!form) {
			return;
		}

		var steps = Array.prototype.slice.call(form.querySelectorAll('[data-registration-step]'));
		var panels = Array.prototype.slice.call(form.querySelectorAll('[data-registration-panel]'));
		var activeStep = 'account';
		var hasCharacterStep = !!form.querySelector('[data-registration-panel="character"]');

		function byId(id) {
			return document.getElementById(id);
		}

		function fieldFilled(id) {
			var field = byId(id);
			return !field || field.value.trim().length > 0;
		}

		function selected(name) {
			return !!form.querySelector('input[name="' + name + '"]:checked');
		}

		function validEmail() {
			var field = byId('email');
			return !!field && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(field.value.trim());
		}

		function validPassword() {
			var password = byId('password');
			var confirm = byId('password_confirm');
			return !!password && !!confirm && password.value.length >= 6 && password.value === confirm.value;
		}

		function accountReady() {
			return fieldFilled('account_input') && validEmail() && validPassword();
		}

		function characterReady() {
			if (!hasCharacterStep) {
				return true;
			}

			var hasVocationChoices = !!form.querySelector('input[name="vocation"]');
			var hasTownChoices = !!form.querySelector('input[name="town"]');

			return fieldFilled('character_name') &&
				selected('sex') &&
				(!hasVocationChoices || selected('vocation')) &&
				(!hasTownChoices || selected('town'));
		}

		function allowedSteps() {
			var allowed = { account: true };
			var accountIsReady = accountReady();
			var characterIsReady = characterReady();

			if (hasCharacterStep) {
				allowed.character = accountIsReady;
				allowed.rules = accountIsReady && characterIsReady;
			}
			else {
				allowed.rules = accountIsReady;
			}

			return allowed;
		}

		function setActiveStep(stepName) {
			activeStep = stepName;

			steps.forEach(function (step) {
				var isActive = step.getAttribute('data-registration-step') === activeStep;
				step.classList.toggle('is-active', isActive);
			});

			panels.forEach(function (panel) {
				var isActive = panel.getAttribute('data-registration-panel') === activeStep;
				panel.classList.toggle('is-active', isActive);
			});
		}

		function refresh() {
			var allowed = allowedSteps();

			steps.forEach(function (step) {
				var stepName = step.getAttribute('data-registration-step');
				var unlocked = !!allowed[stepName];
				step.disabled = !unlocked;
				step.classList.toggle('is-locked', !unlocked);
				step.classList.toggle('is-complete', stepName === 'account' ? accountReady() : stepName === 'character' ? characterReady() : !!byId('accept_rules') && byId('accept_rules').checked);
			});

			panels.forEach(function (panel) {
				var panelName = panel.getAttribute('data-registration-panel');
				panel.classList.toggle('is-locked', !allowed[panelName]);
			});

			if (!allowed[activeStep]) {
				setActiveStep('account');
			}
		}

		steps.forEach(function (step) {
			step.addEventListener('click', function () {
				if (!step.disabled) {
					setActiveStep(step.getAttribute('data-registration-step'));
				}
			});
		});

		form.addEventListener('input', refresh);
		form.addEventListener('change', refresh);
		refresh();
	})();
</script>
<style>
	#SuggestAccountNumber {
		font-size: 7pt;
	}
</style>
