<div class="eclipse-online-page">
	<section class="online-hero">
		<div>
			<h2>Quem está online?</h2>
			<p>Acompanhe os jogadores ativos no Eclipse OT.</p>
		</div>
		<div class="online-total">
			<strong>{{ players|length }}</strong>
			<span>jogador{{ players|length == 1 ? '' : 'es' }} online</span>
		</div>
	</section>

	<div class="online-grid">
		<section class="online-card online-world-card">
			<div class="online-card-title">Informações do Mundo</div>
			<div class="online-info-list">
				{% if not status.online %}
					<div class="online-offline">
						<strong>{{ config.lua.serverName }} está offline.</strong>
						<span>Tente novamente em alguns minutos.</span>
					</div>
				{% else %}
					<div><span>Status</span><strong class="online-status">Online</strong></div>
					<div><span>Jogadores Online</span><strong>{{ players|length }}</strong></div>
					<div><span>Recorde Online</span><strong>{{ record|raw }}</strong></div>
					<div>
						<span>Datacenter</span>
						<strong>{{ setting('core.online_datacenter')|raw }}</strong>
					</div>
					<div>
						<span>Data do servidor</span>
						<strong>{{ "now"|date("d/m/Y H:i:s") }}</strong>
					</div>
				{% endif %}
			</div>
		</section>

		<section class="online-card online-frags-card">
			<div class="online-card-title">Frags</div>
			<div class="online-frag-list">
				<div>
					<img src="images/white_skull.gif" alt="White Skull">
					<span>1 - 6 frags</span>
				</div>
				<div>
					<img src="images/red_skull.gif" alt="Red Skull">
					<span>6+ frags ou Red Skull</span>
				</div>
				<div>
					<img src="images/black_skull.gif" alt="Black Skull">
					<span>10+ frags ou Black Skull</span>
				</div>
			</div>
		</section>
	</div>

	<section class="online-card online-vocations-card">
		<div class="online-card-title">Vocações Online</div>
		<div class="online-vocation-grid">
			{% for vocationId in baseVocations %}
				<div class="online-vocation">
					<strong>{{ config('vocations')[vocationId] }}s</strong>
					<span>{{ vocs[vocationId] }}</span>
				</div>
			{% endfor %}
		</div>
	</section>

	<section class="online-card online-players-card">
		<div class="online-card-title">Jogadores Online</div>
		{% if players|length == 0 %}
			<div class="online-empty">
				<strong>Nenhum jogador online no momento.</strong>
				<span>O próximo aventureiro pode ser você.</span>
			</div>
		{% else %}
			<div class="online-table-wrap">
				<table class="online-table">
					<thead>
					<tr>
						{% if config.account_country %}
							<th class="online-country">#</th>
						{% endif %}
						{% if config.online_outfit %}
							<th class="online-outfit">Outfit</th>
						{% endif %}
						<th>
							<a href="{{ getLink('online')}}?order=name_{{ order == 'name_asc' ? 'desc' : 'asc' }}">Nome</a>
						</th>
						<th>
							<a href="{{ getLink('online')}}?order=level_{{ order == 'level_asc' ? 'desc' : 'asc' }}">Level</a>
						</th>
						<th>
							<a href="{{ getLink('online')}}?order=vocation_{{ order == 'vocation_asc' ? 'desc' : 'asc' }}">Vocação</a>
						</th>
					</tr>
					</thead>
					<tbody>
					{% for player in players %}
						<tr>
							{% if config.account_country %}
								<td class="online-country">{{ player.country_image|raw }}</td>
							{% endif %}
							{% if config.online_outfit %}
								<td class="online-outfit">
									<img src="{{ player.outfit }}" alt="outfit de {{ player.name|striptags }}">
								</td>
							{% endif %}
							<td class="online-player-name">{{ player.name|raw }}{{ player.skull }}</td>
							<td><strong>{{ player.level }}</strong></td>
							<td>{{ player.vocation }}</td>
						</tr>
					{% endfor %}
					</tbody>
				</table>
			</div>
		{% endif %}
	</section>
</div>
