<div class="eclipse-characters-page eclipse-characters-result eclipse-character-compact">
  {% if canEdit %}
    <div class="character-admin-action">
      <a href="admin/?p=players&id={{ player.getId() }}" title="Editar no painel admin" target="_blank">
        {% set button_name = 'Editar personagem' %}
        {% include('buttons.base.html.twig') %}
      </a>
    </div>
  {% endif %}

  <div class="character-profile-header">
    {% if outfit is not null %}
      <div class="character-outfit-frame">
        <img src="{{ outfit }}" alt="Outfit de {{ player.getName() }}">
      </div>
    {% endif %}

    <div class="character-profile-main">
      <span class="character-profile-kicker">Personagem</span>
      <h2>{{ player.getName() }}</h2>
      <div class="character-profile-meta">
        <span class="character-stat-pill">Level <strong>{{ player.getLevel() }}</strong></span>
        <span class="character-stat-pill">Vocação <strong>{{ vocation }}</strong></span>
      </div>
    </div>

    <div class="character-profile-status {% if player.isOnline() %}is-online{% else %}is-offline{% endif %}">
      {% if player.isOnline() %}Online{% else %}Offline{% endif %}
    </div>
  </div>

  {% if hidden %}
    <div class="character-hidden-message">
      Este personagem está oculto.
    </div>
  {% else %}
    <div class="character-info-grid">
      <section class="character-data-card">
        <div class="character-card-title">Informações do Personagem</div>
        <table class="character-data-table">
          <tbody>
          <tr>
            <th>Sex:</th>
            <td>{{ sex }}</td>
          </tr>
          <tr>
            <th>Vocation:</th>
            <td>{{ vocation }}</td>
          </tr>
          <tr>
            <th>Level:</th>
            <td>{{ player.getLevel() }}</td>
          </tr>
          <tr>
            <th>Achievement Points:</th>
            <td>{{ achievementPoints }}</td>
          </tr>
          <tr>
            <th>Residence:</th>
            <td>{{ town }}</td>
          </tr>
          <tr>
            <th>Last Login:</th>
            <td>{% if player.getLastLogin() == 0 %}Nunca entrou.{% else %}{{ player.getLastLogin()|date("d/m/Y H:i:s") }}{% endif %}</td>
          </tr>
          <tr>
            <th>Account Status:</th>
            <td>{% if account.isPremium() %}Premium Account{% else %}Free Account{% endif %}</td>
          </tr>
          </tbody>
        </table>
      </section>

      <section class="character-data-card">
        <div class="character-card-title">Account Information</div>
        <table class="character-data-table">
          <tbody>
          <tr>
            <th>Created:</th>
            <td>{{ account.getCreated()|date("d/m/Y H:i:s") }}</td>
          </tr>
          </tbody>
        </table>
      </section>
    </div>

    <div class="character-skills-card">
      <div class="character-card-title">Skills</div>
      <div class="character-skills-layout character-skills-horizontal">
        <table class="character-skill-table character-skill-strip">
          <thead>
          <tr>
            <th><img src="https://www.tibiawiki.com.br/images/0/05/Journal_Shield.gif" alt="Level"></th>
            <th><img src="https://www.tibiawiki.com.br/images/3/31/Lasting_Exercise_Rod.gif" alt="Magic Level"></th>
            <th><img src="https://www.tibiawiki.com.br/images/8/8a/Pair_of_Iron_Fists.gif" alt="Fist"></th>
            <th><img src="https://www.tibiawiki.com.br/images/3/3b/Lasting_Exercise_Club.gif" alt="Club"></th>
            <th><img src="https://www.tibiawiki.com.br/images/d/db/Lasting_Exercise_Sword.gif" alt="Sword"></th>
            <th><img src="https://www.tibiawiki.com.br/images/4/44/Lasting_Exercise_Axe.gif" alt="Axe"></th>
            <th><img src="https://www.tibiawiki.com.br/images/7/7c/Lasting_Exercise_Bow.gif" alt="Distance"></th>
            <th><img src="https://www.tibiawiki.com.br/images/2/2f/Broken_Wooden_Shield.gif" alt="Defense"></th>
            <th><img src="https://www.tibiawiki.com.br/images/1/1f/Fishing_Rod.gif" alt="Fishing"></th>
          </tr>
          </thead>
          <tbody>
          <tr class="character-skill-labels">
            <td>Level</td>
            <td>ML</td>
            <td>Fist</td>
            <td>Club</td>
            <td>Sword</td>
            <td>Axe</td>
            <td>Dist</td>
            <td>Def</td>
            <td>Fish</td>
          </tr>
          <tr class="character-skill-values">
            <td>{{ player.getLevel() }}</td>
            {% for skill in skills %}
              <td>{{ skill.value }}</td>
            {% else %}
              <td colspan="8">Skills indisponíveis.</td>
            {% endfor %}
          </tr>
          </tbody>
        </table>
      </div>
    </div>

    {% if account_players is not null and account_players|length > 0 %}
      <section class="character-data-card character-characters-card">
        <div class="character-card-title">Characters</div>
        <table class="character-data-table character-list-table">
          <thead>
          <tr>
            <th>Name</th>
            <th>Level</th>
            <th>Vocation</th>
            <th>Status</th>
          </tr>
          </thead>
          <tbody>
          {% for character in account_players %}
            <tr>
              <td>
                <a href="{{ getLink('characters') }}/{{ character.getName()|urlencode }}">{{ character.getName() }}</a>
              </td>
              <td>{{ character.getLevel() }}</td>
              <td>{{ character.getVocationName() }}</td>
              <td>{% if character.isOnline() %}Online{% else %}Offline{% endif %}</td>
            </tr>
          {% endfor %}
          </tbody>
        </table>
      </section>
    {% endif %}
  {% endif %}

  {{ hook(constant('HOOK_CHARACTERS_AFTER_SKILLS')) }}
  {{ hook(constant('HOOK_CHARACTERS_AFTER_CHARACTERS')) }}

  <div class="character-search-repeat">
    {{ search_form|raw }}
  </div>
</div>
